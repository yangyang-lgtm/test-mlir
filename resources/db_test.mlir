module {
  tt.func public @kernel(%a: !tt.ptr<f32> {tt.divisibility = 16 : i32} loc("a"(#loc)), %b: !tt.ptr<f32> {tt.divisibility = 16 : i32} loc("b"(#loc)), %c: !tt.ptr<f32> {tt.divisibility = 16 : i32} loc("c"(#loc)), %num: i32 {tt.divisibility = 16 : i32} loc("num"(#loc))) attributes {noinline = false} {
    %c128_i32 = arith.constant 128 : i32 loc(#loc1)
    %pid = tt.get_program_id x : i32 loc(#loc19)
    %base = arith.muli %pid, %num : i32 loc(#loc20)
    scf.for %offset = %base to %num step %c128_i32  : i32 {
      %mask_offset = tt.make_range {end = 128 : i32, start = 0 : i32} : tensor<128xi32> loc(#loc21)
      %mask_offset_0 = tt.splat %offset : i32 -> tensor<128xi32> loc(#loc22)
      %mask_offset_1 = arith.addi %mask_offset, %mask_offset_0 : tensor<128xi32> loc(#loc22)
      %mask = tt.splat %num : i32 -> tensor<128xi32> loc(#loc23)
      %mask_2 = arith.cmpi slt, %mask_offset_1, %mask : tensor<128xi32> loc(#loc23)
      %ta = tt.splat %a : !tt.ptr<f32> -> tensor<128x!tt.ptr<f32>> loc(#loc24)
      %ta_3 = tt.addptr %ta, %mask_offset_1 : tensor<128x!tt.ptr<f32>>, tensor<128xi32> loc(#loc24)
      %ta_4 = tt.load %ta_3, %mask_2 : tensor<128x!tt.ptr<f32>> loc(#loc25)
      %tb = tt.splat %b : !tt.ptr<f32> -> tensor<128x!tt.ptr<f32>> loc(#loc26)
      %tb_5 = tt.addptr %tb, %mask_offset_1 : tensor<128x!tt.ptr<f32>>, tensor<128xi32> loc(#loc26)
      %tb_6 = tt.load %tb_5, %mask_2 : tensor<128x!tt.ptr<f32>> loc(#loc27)
      %out = arith.addf %ta_4, %tb_6 : tensor<128xf32> loc(#loc28)
      %0 = tt.splat %c : !tt.ptr<f32> -> tensor<128x!tt.ptr<f32>> loc(#loc12)
      %1 = tt.addptr %0, %mask_offset_1 : tensor<128x!tt.ptr<f32>>, tensor<128xi32> loc(#loc12)
      tt.store %1, %out, %mask_2 : tensor<128x!tt.ptr<f32>> loc(#loc13)
    } {all_parallel, tiled_generic} loc(#loc1)
    tt.return loc(#loc14)
  } loc(#loc)
} loc(#loc)
